SHOPIFY_SHOP_DOMAIN=velotric-dealers-shop.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Optional: use this instead of client credentials if Shopify provides a static Admin API token.
# SHOPIFY_ADMIN_ACCESS_TOKEN=

SHOPIFY_API_VERSION=2026-01

FEISHU_LANTERN_CHAT_ID=oc_e7d5c76b3623d0f7f3809309861d5b54
# Optional: comma-separated additional chat IDs that Lantern may answer in.
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_WEBHOOK_PATH=/feishu/events
PORT=3000

FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_API_BASE_URL=https://apis.fedex.com

# Production/standalone should set this explicitly. Local Codex sessions can
# fall back to ~/.codex/config.toml while we are prototyping.
SURPATH_MCP_URL=
